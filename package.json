{
  "name": "@stellar/wallet-backend-client",
  "version": "0.1.0",
  "description": "Universal TypeScript GraphQL client for Stellar Wallet Backend with JWT authentication",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run codegen && tsc",
    "codegen": "graphql-codegen --config codegen.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "keywords": [
    "stellar",
    "graphql",
    "wallet",
    "jwt",
    "authentication",
    "typescript",
    "client",
    "universal",
    "browser",
    "react",
    "react-native"
  ],
  "author": "Stellar Development Foundation",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/stellar/wallet-backend-client.git"
  },
  "bugs": {
    "url": "https://github.com/stellar/wallet-backend-client/issues"
  },
  "homepage": "https://github.com/stellar/wallet-backend-client#readme",
  "dependencies": {
    "@stellar/stellar-sdk": "^13.3.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "cross-fetch": "^4.0.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/client-preset": "4.8.3",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.8"
  }
}
