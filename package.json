{
  "name": "@stellar/wallet-backend-client",
  "version": "0.1.0",
  "description": "Universal TypeScript GraphQL client for Stellar Wallet Backend with JWT authentication",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.14.0"
  },
  "browser": {
    "crypto": false,
    "buffer": false
  },
  "scripts": {
    "build": "npm run codegen && tsc",
    "codegen": "graphql-codegen --config codegen.ts",
    "test": "npm run test:node && npm run test:browser",
    "test:node": "jest",
    "test:browser": "jest --testEnvironment jsdom",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "prepack": "npm run build"
  },
  "keywords": [
    "stellar",
    "wallet",
    "wallet-backend",
    "graphql",
    "typescript"
  ],
  "sideEffects": false,
  "unpkg": "dist/index.js",
  "jsdelivr": "dist/index.js",
  "author": "Stellar Development Foundation",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/stellar/wallet-backend-client.git"
  },
  "bugs": {
    "url": "https://github.com/stellar/wallet-backend-client/issues"
  },
  "homepage": "https://github.com/stellar/wallet-backend-client#readme",
  "dependencies": {
    "@stellar/stellar-sdk": "^13.3.0",
    "cross-fetch": "^4.0.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/client-preset": "4.8.3",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.0.0",
    "dotenv": "^16.3.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.5",
    "jsdom": "^23.0.1",
    "text-encoding": "^0.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.0.0"
  }
}
